enum Rarity {
    Commun
    Rare
    Epique
    Legendaire
}



model Insect {

    id         Int     @id @default(autoincrement())
    name        String  
    sciName    String

    featured   Boolean @default(false)
    rarity     Rarity @default(Commun)

    description String?

    imageKey    String?

    userInsects UserInsect[]
}

model UserInsect {

    id Int @id @default(autoincrement())

    userId String
    insectId Int

    quantity Int @default(1)

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
    insect Insect @relation(fields: [insectId], references: [id], onDelete: Cascade)

    @@unique([userId, insectId])
}